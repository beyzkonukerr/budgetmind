PORT=5000
# Bulutta kalici disk ornegi: /data/budgetmind.db (Railway volume ile)
# DATABASE_PATH=./budgetmind.db
ADMIN_PASSWORD=admin123
# Production: en az 32 karakter, rastgele
JWT_SECRET=change_this_secret
# Production: sadece kendi siteniz (virgulle birden fazla). Bos = CORS genis.
# CORS_ORIGIN=https://sizin-app.fly.dev
# Productionda X-Admin-Password ile girisi acmak (onerilmez): ALLOW_LEGACY_ADMIN_HEADER=true
# Gelistirmede legacy kapatmak: DISABLE_LEGACY_ADMIN_HEADER=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
PASSWORD_MIN_LENGTH=8
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
